{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-and-test",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cmake -S . -B build-qt && cmake --build build-qt --config Debug && ctest --test-dir build-qt -C Debug --output-on-failure"
			],
			"isBackground": false,
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "cppbuild",
			"label": "C/C++: cl.exe build active file",
			"command": "cl.exe",
			"args": [
				"/Zi",
				"/EHsc",
				"/nologo",
				"/I${workspaceFolder}\\include",
				"/I${workspaceFolder}\\third_party\\googletest\\include",
				"/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
				"${file}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$msCompile"
			],
			"detail": "Task generated by Debugger."
		},
		{
			"label": "verify-build-and-test-now",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cmake -S . -B build-qt && cmake --build build-qt --config Debug && ctest --test-dir build-qt -C Debug --output-on-failure"
			],
			"isBackground": false
		}
	]
}
